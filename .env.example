# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.

# Required for the LLM Explanation Service (DeepSeek).
# If left empty, the backend automatically falls back to a deterministic
# template-based explanation (see backend/app/deepseek_client.py).
DEEPSEEK_API_KEY=

# Optional overrides (defaults shown)
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=400
DEEPSEEK_TEMPERATURE=0.3
DEEPSEEK_TIMEOUT_SECONDS=20

# Optional: path override for the training dataset
DATASET_PATH=loan_approval_dataset.csv
