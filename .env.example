# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.

# Required for the LLM Explanation Service (DeepSeek).
# If left empty, the backend automatically falls back to a deterministic
# template-based explanation (see backend/app/deepseek_client.py).
DEEPSEEK_API_KEY=

# Optional overrides (defaults shown)
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=400
DEEPSEEK_TEMPERATURE=0.3
DEEPSEEK_TIMEOUT_SECONDS=20

# Optional: path override for the training dataset
DATASET_PATH=loan_approval_dataset.csv

# JWT signing secret. If left empty, an ephemeral key is generated at process
# start (sessions will not survive a server restart). Set a stable secret
# for any persistent deployment.
JWT_SECRET_KEY=

# Default admin account created automatically on first run if no users exist.
# Change the password immediately after first login.
DEFAULT_ADMIN_EMAIL=admin@hcxai.local
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
