# Copy this file to .env and configure your environment

# DeepSeek API Key (optional - system falls back to template if not provided)
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-key-here

# Database (SQLite by default - for production, switch to PostgreSQL)
DATABASE_URL=sqlite:///./data/hcxai.db

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here

# CORS Origins (comma-separated, no spaces)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Model training seed
RANDOM_STATE=42
